<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="30dp"
    android:background="@color/color_bg_body"> <ImageView
    android:layout_width="100dp"
    android:layout_height="100dp"
    android:src="@android:drawable/ic_popup_sync"
    android:contentDescription="Icono Sync"
    android:layout_marginBottom="20dp"
    app:tint="?attr/colorPrimary"/> <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Sincronización de Datos"
    android:textSize="24sp"
    android:textStyle="bold"
    android:textColor="@color/color_text_dark" android:layout_marginBottom="10dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Descarga las últimas Actividades y Personas del servidor para trabajar sin conexión."
        android:textAlignment="center"
        android:textColor="@color/color_text_medium" android:textSize="14sp"
        android:layout_marginBottom="40dp"/>

    <ProgressBar
        android:id="@+id/progressBarSync"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btnSync"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Sincronizar Ahora"
        android:textSize="16sp"
        android:backgroundTint="?attr/colorPrimary" android:textColor="?attr/colorOnPrimary"/> <TextView
        android:id="@+id/tvSyncStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Listo para sincronizar"
        android:layout_marginTop="20dp"
        android:textColor="@color/color_text_light" android:textSize="12sp"/>

</LinearLayout>