<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nueva Actividad"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_marginBottom="20dp"/>

        <TextView android:text="Nombre de la Actividad" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <EditText
            android:id="@+id/etNombreAct"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="15dp"/>

        <TextView android:text="Tipo de Actividad" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <Spinner
            android:id="@+id/spinnerTipoAct"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@android:drawable/btn_dropdown"
            android:layout_marginBottom="15dp"/>

        <TextView android:text="Fecha" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <EditText
            android:id="@+id/etFechaAct"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:focusable="false"
            android:background="@android:drawable/edit_text"
            android:hint="Seleccionar Fecha"
            android:layout_marginBottom="15dp"/>

        <TextView android:text="Lugar / Ubicación" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <EditText
            android:id="@+id/etLugarAct"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="15dp"/>

        <TextView android:text="Descripción (Opcional)" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <EditText
            android:id="@+id/etDescAct"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:gravity="top|start"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnGuardarAct"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Crear Actividad"
            android:backgroundTint="#2196F3"/>

    </LinearLayout>
</ScrollView>