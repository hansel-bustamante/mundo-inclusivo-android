<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvTituloAct"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nombre Actividad"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:id="@+id/lblPart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvTituloAct"
        android:text="Lista de Participantes Inscritos:"
        android:textColor="#666"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvParticipantes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/lblPart"
        android:layout_above="@id/layoutBotones"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"/>

    <LinearLayout
        android:id="@+id/layoutBotones"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnAgregarParticipante"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="+ Agregar Participante"
            android:backgroundTint="#4CAF50"/>

        <Button
            android:id="@+id/btnVerSesiones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ver Sesiones →"
            android:backgroundTint="#2196F3"
            android:layout_marginTop="5dp"/>
    </LinearLayout>

</RelativeLayout>